---
import type { ESPNGeoBroadcast, ESPNScheduleEvent } from "../../resources/game";
import { NETWORK_MAPPINGS } from "../../utils/constants";


const { game } = Astro.props;

const espnGame = (game as ESPNScheduleEvent);
let networkName: string | null = null;
if (espnGame.competitions[0].geoBroadcasts.length > 0 && espnGame.competitions[0].geoBroadcasts[0].media?.shortName) {
    networkName = espnGame.competitions[0].geoBroadcasts[0].media.shortName;
} else if (espnGame.competitions[0].broadcasts.length > 0 && espnGame.competitions[0].broadcasts[0].media?.shortName) {
    networkName = espnGame.competitions[0].broadcasts[0].media.shortName;
}

const networkMapping = networkName ? NETWORK_MAPPINGS[networkName] : null;
const networkURL = (networkName?.includes('ESPN') || networkName?.includes('LHN') || networkName?.includes('Longhorn Network') || networkName?.includes('ACCN') || networkName?.includes('ACC Network') || networkName?.includes('SEC Network') || networkName?.includes('SECN') || networkName?.includes('BIG12') || networkName?.includes('ABC')) ? `https://www.espn.com/watch/player/_/eventCalendarId/${espnGame.id}` : networkMapping;
---

<Fragment>
    {
        (networkURL) && <a class="btn btn-sm btn-outline-secondary" role="button" target="_blank" href={networkURL}>{networkName}</a>
    }
    {
        (!networkURL && networkName) && <span class="badge bg-secondary bg-sm align-self-center">{networkName}</span>
    }
</Fragment>