---
import type { ESPNCompetitor, ESPNScheduleEvent } from "../../resources/espn";
import { calculateSpiceLevel, formatScore, getRecordString, isChampionshipEvent } from "../../utils/common";
import BroadcastButton from "./BroadcastButton.astro";
import GameSituation from "./GameSituation.astro";
import TeamRow from "./TeamRow.astro";
import {DateTime} from "luxon";

interface Props {
  game: ESPNScheduleEvent
}

const { game } = Astro.props;

const espnGame = (game as ESPNScheduleEvent);
const espnGameComp = espnGame.competitions[0];
const homeComp = espnGameComp.competitors[0];
const awayComp = espnGameComp.competitors[1];
const homeScore = homeComp.score;
const awayScore = awayComp.score;

const spiceLevel = calculateSpiceLevel(espnGame) || 'none';
const isChamp = isChampionshipEvent(espnGame);

const btnTheme = isChamp ? "btn-outline-championship" : "btn-outline-primary";

const borderClass = (spiceLevel == 'none' && isChamp) ? "" : `spice-level-${spiceLevel}`;
const outlineClass = (isChamp) ? "outline-championship" : "";
const textClass = (isChamp) ? "text-championship" : "text-primary";

let espnGameDateHtml = espnGameComp.status.type.detail;
if (espnGame.status.type.name.includes("STATUS_SCHEDULED")) {
    const dateString = DateTime.fromISO(espnGame.date).toLocaleString(DateTime.DATETIME_SHORT);
    espnGameDateHtml = `<span class="game-date">${dateString}</span>`;
} else if (espnGame.status.type.completed == true) {
    const dateString = DateTime.fromISO(espnGame.date).toLocaleString(DateTime.DATE_SHORT);
    espnGameDateHtml = `<span class="game-status">${espnGame.status.type.detail} -</span> <span class="game-date">${dateString}</span>`  
} else {
    espnGameDateHtml = espnGameComp.status.type.detail
}

const hasLastPlay = (espnGameComp.situation && espnGameComp.situation?.lastPlay);
const canShowSituation = (
    (!(espnGame.status.type.completed == true || espnGame.status.type.detail.includes("Cancel") || espnGame.status.type.detail.includes("Postpone")))
    && (espnGameComp.situation != null && espnGameComp.situation.lastPlay != null)
)
const canLoadStats = (
    (espnGame.status.type.name.includes("STATUS_DELAYED") && !hasLastPlay) 
    || espnGame.status.type.detail.includes("Cancel") 
    || espnGame.status.type.detail.includes("Postpone") 
    || (espnGame.status.type.name.includes("STATUS_IN_PROGRESS") && !hasLastPlay)
)
const canLoadStatsTheme = canLoadStats ? `disabled` : ``
---

<div class="col-xl-3 col-lg-6">
    <div class={`row border rounded m-2 mb-4 ${outlineClass} ${borderClass}`}>
        <div class="col p-3">
            <div class="d-flex justify-content-between">
                <strong class={`d-inline-block mb-2 ${textClass} game-context small`} set:html={espnGameDateHtml}></strong>
            </div>
            <TeamRow espnComp={awayComp} espnStatus={espnGame.status} winner={parseInt(awayScore) > parseInt(homeScore)} completed={espnGame.status.type.completed == true} hasBall={espnGameComp.situation?.lastPlay?.end?.team?.id == awayComp.id} isRedZone={espnGameComp.situation?.isRedZone} spacer="" />
            <TeamRow espnComp={homeComp} espnStatus={espnGame.status} winner={parseInt(awayScore) < parseInt(homeScore)} completed={espnGame.status.type.completed == true} hasBall={espnGameComp.situation?.lastPlay?.end?.team?.id == homeComp.id} isRedZone={espnGameComp.situation?.isRedZone} spacer="mb-3" />
            <GameSituation hidden={canShowSituation} game={espnGame} />
            <div class="d-flex justify-content-between">
                <div class="text-left">
                    <a class=`btn btn-sm ${btnTheme} ${canLoadStatsTheme}` role="button" href={`/cfb/game/${espnGame.id}`}>{ (espnGame.status.type.name.includes("STATUS_SCHEDULED")) ? "Preview" : "Stats" }</a>
                </div>
                <div class="text-right">
                    <BroadcastButton game={espnGame} />
                </div>
            </div>
        </div>
    </div>
</div>