---
import type { ESPNTeam } from '../../resources/espn'
import type { TeamSummary } from '../../resources/summary'
import { formatRank, generateMarginalString } from '../../utils/common'
import { cleanLocation, generateColorRampValue, getNumberWithOrdinal, roundNumber } from '../../utils/misc'

interface Props {
    team: ESPNTeam
    season: string | number
    teamSeasonData: any
    summary?: TeamSummary | null
    hideNavigation: boolean
}

const { team, season, teamSeasonData, summary, hideNavigation } = Astro.props;

const records = Array.isArray(teamSeasonData["record"]) ? teamSeasonData["record"] : [];
const overallStuff = records.filter(item => item["type"] == "total")[0];
const overall = overallStuff?.displayValue || "0-0";
const finishes = overallStuff?.stats?.filter((item: any) => item.name == "playoffSeed") || []
const finish = (finishes.length > 0) ? getNumberWithOrdinal(parseInt(finishes[0].displayValue)) : 'N/A';

var conf = ""
let confRecs = records.filter(item => item.type == "vsconf")
if (confRecs.length > 0) {
    conf = ` (Conf: ${confRecs[0].displayValue})`;
} else {
    conf = ""
}

const metricSeason = (summary?.season && season != summary?.season) ? `${summary.season} ` : "";
---


<div class="card border rounded">
    <div class="card-body">
        <div class="card-title mb-0">
            <div class="d-flex align-items-center justify-content-between">
                <h2>{cleanLocation(team)}</h2>
                <img class={`h2 img img-fluid me-1 team-logo-${team.id}`} width="50px" src={`https://a.espncdn.com/i/teamlogos/ncaa/500/${team.id}.png`} /> 
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-responsive">
                <thead>
                    <th class="text-center" style="width: 33%">{season} Record</th>
                    <th class="text-center" style="width: 33%">{season} Conf Finish</th>
                    <th class="text-center" style="width: 33%">{metricSeason}EPA/Play</th>
                </thead>
                <tbody>
                    <tr>
                        <td class="numeral text-center" style="width: 33%">{overall}{conf}</td>
                        <td class="numeral text-center" style="width: 33%">{finish}</td>
                        <td style="width: 33%" class={`numeral text-center ${generateColorRampValue(summary?.differential?.overall?.epaPerPlayRank, 134)}`}>{generateMarginalString(summary?.differential?.overall?.epaPerPlay, 2, 2)} <span class="align-self-center text-small" style="opacity: 50%"> #{formatRank(summary?.differential?.overall?.epaPerPlayRank)}</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="table-responsive pe-0">
            <table class="table table-sm table-responsive">
                <caption class="text-muted">
                    <small>
                        <p class="mb-0">Stats shown as margins. AY% (available yards pct) concept from Brian Fremeau (<a href="http://bcftoys.com">http://bcftoys.com</a>).</p>
                    </small>
                </caption>
                <thead>
                    <th class="text-center" style="width: 33%">{metricSeason}Yards/Play</th>
                    <th class="text-center" style="width: 33%">{metricSeason}AY%</th>
                    <th class="text-center" style="width: 33%">{metricSeason}Success %</th>
                </thead>
                <tbody>
                    <tr>
                        <td class={`numeral text-center ${generateColorRampValue(summary?.differential?.overall?.yardsPerPlayRank, 134, false)}`} style="width: 33%">{generateMarginalString(summary?.differential?.overall?.yardsPerPlay, 2, 2)} <span class="align-self-center text-small" style="opacity: 50%"> #{formatRank(summary?.differential?.overall?.yardsPerPlayRank)}</span></td>
                        <td class={`numeral text-center ${generateColorRampValue(summary?.differential?.overall?.availableYardsPctRank, 134, false)}`} style="width: 33%">{generateMarginalString((summary?.differential?.overall?.availableYardsPct || summary?.differential?.overall?.availableYardsPct == 0) ? (100 * summary?.differential?.overall?.availableYardsPct) : null, 2, 1)}% <span class="align-self-center text-small" style="opacity: 50%"> #{formatRank(summary?.differential?.overall?.availableYardsPctRank)}</span></td>
                        <td class={`numeral text-center ${generateColorRampValue(summary?.differential?.overall?.successRateRank, 134, false)}`} style="width: 33%">{generateMarginalString((summary?.differential?.overall?.successRate || summary?.differential?.overall?.successRate == 0) ? 100 * summary?.differential?.overall?.successRate : null, 2, 1)}% <span class="align-self-center text-small" style="opacity: 50%"> #{formatRank(summary?.differential?.overall?.successRateRank)}</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        {
            (summary && !hideNavigation) && (<a class="text-left" href={`/cfb/year/${metricSeason.trim()}/team/${team.id}`}>View full profile</a>)
        }
    </div>
</div>