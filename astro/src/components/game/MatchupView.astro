<div class="container mb-3">
    <MatchupRadarChart client:only awayTeam={awayTeam} homeTeam={homeTeam} teamData={matchupData} />
    <div class="row">
        <Fragment set:html={produceTeamSector(awayTeam, awayTeamBreakdown)} />
        <div class="col-md-12 ms-sm-auto col-lg-6">
            <div class="h3 text-center"><Fragment set:html={produceTeamLogoLink(awayTeam, "h3", false)} /> Offense vs <Fragment set:html={produceTeamLogoLink(homeTeam, "h3", false)} /> Defense</div>
            <div class="table-responsive">
                <table class="table table-sm table-responsive">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 10% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 20% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 40% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 20% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 10% !important;" colspan="1"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <Fragment set:html={produceMatchupRow("EPA/Pass", awayTeamBreakdown, homeTeamBreakdown, "offensive", "passing", "epaPerPlay")} />
                        <Fragment set:html={produceMatchupRow("EPA/Rush", awayTeamBreakdown, homeTeamBreakdown, "offensive", "rushing", "epaPerPlay")} />
                        <Fragment set:html={produceMatchupRow("Available Yards %", awayTeamBreakdown, homeTeamBreakdown, "offensive", "overall", "availableYardsPct")} />
                        <Fragment set:html={produceMatchupRow("Starting Field Position", awayTeamBreakdown, homeTeamBreakdown, "offensive", "overall", "startingFP")} />
                        <Fragment set:html={produceMatchupRow("Early Downs EPA/Play", awayTeamBreakdown, homeTeamBreakdown, "offensive", "overall", "earlyDownEPAPerPlay")} />
                        <Fragment set:html={produceMatchupRow("3rd/4th Down Success", awayTeamBreakdown, homeTeamBreakdown, "offensive", "overall", "lateDownSuccessRate")} />
                        <Fragment set:html={produceMatchupRow("Avg 3rd Down Distance", awayTeamBreakdown, homeTeamBreakdown, "offensive", "overall", "thirdDownDistance")} />
                    </tbody>
                </table>
            </div>
            <div class="h3 text-center"><Fragment set:html={produceTeamLogoLink(awayTeam, "h3", false)} /> Defense vs <Fragment set:html={produceTeamLogoLink(homeTeam, "h3", false)} /> Offense</div>
            <div class="table-responsive">
                <table class="table table-sm table-responsive">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 10% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 20% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 40% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 20% !important;" colspan="1"></th>
                            <th class="text-center" style="width: 10% !important;" colspan="1"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <Fragment set:html={produceMatchupRow("EPA/Pass", awayTeamBreakdown, homeTeamBreakdown, "defensive", "passing", "epaPerPlay")} />
                        <Fragment set:html={produceMatchupRow("EPA/Rush", awayTeamBreakdown, homeTeamBreakdown, "defensive", "rushing", "epaPerPlay")} />
                        <Fragment set:html={produceMatchupRow("Available Yards %", awayTeamBreakdown, homeTeamBreakdown, "defensive", "overall", "availableYardsPct")} />
                        <Fragment set:html={produceMatchupRow("Starting FP", awayTeamBreakdown, homeTeamBreakdown, "defensive", "overall", "startingFP")} />
                        <Fragment set:html={produceMatchupRow("Early Downs EPA/Play", awayTeamBreakdown, homeTeamBreakdown, "defensive", "overall", "earlyDownEPAPerPlay")} />
                        <Fragment set:html={produceMatchupRow("3rd/4th Down Success", awayTeamBreakdown, homeTeamBreakdown, "defensive", "overall", "thirdDownSuccessRate")} />
                        <Fragment set:html={produceMatchupRow("Avg 3rd Down Distance", awayTeamBreakdown, homeTeamBreakdown, "defensive", "overall", "thirdDownDistance")} />
                    </tbody>
                </table>
            </div>
        </div>
        <Fragment set:html={produceTeamSector(homeTeam, homeTeamBreakdown)} />
    </div>
    <div class="row mb-3">
        <div class="col-12">
            <p class="m-0 text-muted text-small">
                <small>Matchup table concept adapted from <a href="https://sumersports.com/games/2024-01-BAL-KC/">SumerSports's NFL matchup pages</a>.</small>
                {(awayTeamBreakdown.season || homeTeamBreakdown.season) && (<small> Ranks from {awayTeamBreakdown.season || homeTeamBreakdown.season} season.</small>)}
            </p>
        </div>
    </div>
</div>
