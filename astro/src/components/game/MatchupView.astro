        <div class="col-lg-4 col-md-12 margin-override">
            <%- include('../../partials/team_card', {
                teamData: awayComp,
                breakdown: [gameData.matchup.team[0]],
                season: season,
                week,
                hideNavigation: false
            }) %>
        </div>
        <div class="col-lg-4 col-md-12">
