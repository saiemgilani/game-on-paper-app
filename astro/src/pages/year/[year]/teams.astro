---
import TeamLeaderboardPage from "../../../components/leaderboards/TeamLeaderboardPage.astro";
import { CURRENT_YEAR, LAST_YEAR } from "../../../utils/constants";

const { year } = Astro.params;
if (year == `${CURRENT_YEAR}`) {
    return Astro.redirect(`/year/${LAST_YEAR}/teams`)
}
---

<TeamLeaderboardPage season={parseInt(year || `${CURRENT_YEAR}`)} category={"differential"} metric={"overall.adjEpaPerPlay"} />