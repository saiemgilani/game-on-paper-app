---
import TeamLeaderboardPage from "../../../../components/leaderboards/TeamLeaderboardPage.astro";
import { CURRENT_YEAR } from "../../../../utils/constants";

const { year, category } = Astro.params;
const query = Astro.url.searchParams;
const metric = query.get("sort") || "overall.epaPerPlay";
---

<TeamLeaderboardPage season={parseInt(year || `${CURRENT_YEAR}`)} category={category} metric={metric} />