---
import SchedulePage from "../../../../../../../components/schedule/SchedulePage.astro";
import { CURRENT_YEAR } from "../../../../../../../utils/constants";

const { year, type, week } = Astro.params;
const group = Astro.url.searchParams.get("group") || "80";
---

<SchedulePage season={parseInt(year || `${CURRENT_YEAR}`)} seasontype={parseInt(type || "2")} week={parseInt(week || "1")} group={parseInt(group)} />