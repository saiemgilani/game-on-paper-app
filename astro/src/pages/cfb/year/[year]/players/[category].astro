---
import PlayerLeaderboardPage from "../../../../../components/leaderboards/PlayerLeaderboardPage.astro";
import { CURRENT_YEAR } from "../../../../../utils/constants";

const { year, category } = Astro.params;
const query = Astro.url.searchParams;
const metric = query.get("sort") || "advanced.epaPerPlay";
if (year == `${CURRENT_YEAR}`) {
    return Astro.redirect(`/cfb/year/${LAST_YEAR}/players/${category}`)
}
---

<PlayerLeaderboardPage season={parseInt(year || `${CURRENT_YEAR}`)} category={category} metric={metric} />