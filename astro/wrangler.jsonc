{
	"compatibility_date": "2026-05-24",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "game-on-paper-astro",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}